Bootstrap: docker
From: python:3.12-slim

%files
    pyproject.toml /opt/app/pyproject.toml
    uv.lock /opt/app/uv.lock
    main.py /opt/app/main.py
    main_drowsiness.py /opt/app/main_drowsiness.py
    evaluate.py /opt/app/evaluate.py
    visualize.py /opt/app/visualize.py
    backends.py /opt/app/backends.py

%post
    set -eu
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y --no-install-recommends \
        libglib2.0-0 \
        ffmpeg \
        ca-certificates \
        curl \
        procps \
        tini \
        zstd
    rm -rf /var/lib/apt/lists/*

    # Ollama サーバ本体をインストール
    curl -fsSL https://ollama.com/install.sh | sh

    pip install --no-cache-dir --upgrade pip
    pip install --no-cache-dir \
        "ollama>=0.6.1" \
        "opencv-python-headless>=4.13.0" \
        "numpy"

    # ホストから models をバインドするためのマウントポイント
    mkdir -p /models /work
    chmod -R a+rX /opt/app

    # Ollama 起動 + Python 実行用のエントリスクリプト
    cat > /opt/app/entrypoint.sh <<'EOS'
#!/bin/bash
set -eu

: "${OLLAMA_MODELS:=/models}"
: "${OLLAMA_HOST:=127.0.0.1:11434}"
: "${BACKEND:=ollama}"
export OLLAMA_MODELS OLLAMA_HOST BACKEND

MODE="${APP_MODE:-python}"
SCRIPT="${APP_SCRIPT:-main.py}"

run_target() {
    case "$MODE" in
        python)  exec python "/opt/app/${SCRIPT}" "$@" ;;
        ollama)  exec ollama "$@" ;;
        *)       echo "Unknown APP_MODE: $MODE" >&2; exit 2 ;;
    esac
}

# 外部 Ollama / llama.cpp バックエンドの場合は Ollama サーバ起動をスキップ
if [ "${USE_EXTERNAL_OLLAMA:-0}" = "1" ] || [ "$BACKEND" = "llama.cpp" ]; then
    run_target "$@"
fi

# Ollama サーバをバックグラウンド起動
ollama serve >/tmp/ollama.log 2>&1 &
OLLAMA_PID=$!
trap 'kill $OLLAMA_PID 2>/dev/null || true' EXIT INT TERM

# 起動待ち（最大30秒）
for i in $(seq 1 60); do
    if curl -fsS "http://${OLLAMA_HOST}/api/version" >/dev/null 2>&1; then
        break
    fi
    sleep 0.5
done

if ! curl -fsS "http://${OLLAMA_HOST}/api/version" >/dev/null 2>&1; then
    echo "Ollama サーバの起動に失敗しました。ログ:" >&2
    cat /tmp/ollama.log >&2
    exit 1
fi

case "$MODE" in
    python) python "/opt/app/${SCRIPT}" "$@" ;;
    ollama) ollama "$@" ;;
    *) echo "Unknown APP_MODE: $MODE" >&2; exit 2 ;;
esac
EOS
    chmod +x /opt/app/entrypoint.sh

%environment
    export PYTHONUNBUFFERED=1
    export PYTHONDONTWRITEBYTECODE=1
    export OLLAMA_MODELS="${OLLAMA_MODELS:-/models}"
    export OLLAMA_HOST="${OLLAMA_HOST:-127.0.0.1:11434}"
    export BACKEND="${BACKEND:-ollama}"

%runscript
    cd /work 2>/dev/null || cd /opt/app
    APP_SCRIPT=main.py exec /opt/app/entrypoint.sh "$@"

%apprun main
    cd /work 2>/dev/null || cd /opt/app
    APP_SCRIPT=main.py exec /opt/app/entrypoint.sh "$@"

%apprun drowsiness
    cd /work 2>/dev/null || cd /opt/app
    APP_SCRIPT=main_drowsiness.py exec /opt/app/entrypoint.sh "$@"

%apprun evaluate
    cd /work 2>/dev/null || cd /opt/app
    APP_SCRIPT=evaluate.py exec /opt/app/entrypoint.sh "$@"

%apprun visualize
    cd /work 2>/dev/null || cd /opt/app
    APP_SCRIPT=visualize.py exec /opt/app/entrypoint.sh "$@"

%apprun serve
    : "${OLLAMA_MODELS:=/models}"
    : "${OLLAMA_HOST:=0.0.0.0:11434}"
    export OLLAMA_MODELS OLLAMA_HOST
    exec ollama serve

%apprun ollama
    APP_MODE=ollama exec /opt/app/entrypoint.sh "$@"

%apprun llama-server
    # 任意のバインドマウントした llama-server バイナリを起動するためのヘルパ
    # 例: singularity run --app llama-server --nv \
    #       --bind /path/to/llama-server:/usr/local/bin/llama-server \
    #       --bind /path/to/models:/models \
    #       rusiian_auto_annotation.sif --model /models/model.gguf --mmproj /models/mmproj.gguf --port 11600
    : "${LLAMA_SERVER_BIN:=llama-server}"
    exec "${LLAMA_SERVER_BIN}" "$@"

%labels
    Name rusiian-auto-annotation
    Version 0.1.0

%help
    ロシア語学習シーンの注視対象を自動判定するツール。
    Ollama と llama.cpp の 2 種類の推論バックエンドをサポートします (デフォルト: ollama)。

    == 準備 (Ollama バックエンド) ==
    ホスト側にモデルディレクトリを用意します（通常は ~/.ollama/models）。
      例: /home/ashida/.ollama/models
    必要なモデル（例 "gemma4:31b"）をホストで
      OLLAMA_MODELS=/path/to/models ollama pull gemma4:31b
    のように事前配置しておいてください。

    == 準備 (llama.cpp バックエンド) ==
    コンテナには llama-server が同梱されていないため、ユーザ側で以下を用意します。
      1) llama-server バイナリ (CUDA ビルド推奨)。例: /opt/llama.cpp/bin/llama-server
      2) GGUF モデル (例: gemma-3-27b-it.gguf)
      3) mmproj GGUF (Vision 用。例: mmproj-gemma-3-27b-it-f16.gguf)
    llama-server はコンテナにバインドマウント、もしくは --bind で PATH に通してください。

    == 実行例 (Ollama) ==
    apptainer run --nv \
      --bind /home/ashida/.ollama/models:/models \
      --bind $PWD:/work --pwd /work \
      rusiian_auto_annotation.sif input/sample.mp4

    == 実行例 (llama.cpp) ==
    BACKEND=llama.cpp apptainer run --nv \
      --bind /opt/llama.cpp/bin/llama-server:/usr/local/bin/llama-server \
      --bind /path/to/gguf:/models \
      --bind $PWD:/work --pwd /work \
      rusiian_auto_annotation.sif input/sample.mp4 \
      --backend llama.cpp \
      --llama-model /models/gemma-3-27b-it.gguf \
      --llama-mmproj /models/mmproj-gemma-3-27b-it-f16.gguf

    == その他 ==
    # evaluate.py / visualize.py
    apptainer run --nv --bind $PWD:/work --pwd /work \
      --app evaluate rusiian_auto_annotation.sif <args>

    # コンテナ内の ollama CLI を直接叩く（pull 等）
    apptainer run --nv --bind /home/ashida/.ollama/models:/models \
      --app ollama rusiian_auto_annotation.sif list

    # 外部で動いている Ollama を使う
    OLLAMA_HOST=http://192.168.1.10:11434 USE_EXTERNAL_OLLAMA=1 \
      apptainer run --bind $PWD:/work --pwd /work \
      rusiian_auto_annotation.sif input/sample.mp4

    # 外部で動いている llama-server を使う
    apptainer run --bind $PWD:/work --pwd /work \
      rusiian_auto_annotation.sif input/sample.mp4 \
      --backend llama.cpp --llama-host http://192.168.1.10:8080
